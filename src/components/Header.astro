---
import { navLinks } from '../data/site';

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

function url(path: string) {
  return `${base}${path === '/' ? '' : path.slice(1)}`;
}

function isActive(linkHref: string) {
  const full = url(linkHref);
  return currentPath === full || currentPath === full.replace(/\/$/, '');
}
---

<header class="site-header">
  <input type="checkbox" id="mobile-toggle" class="mobile-toggle" />

  <nav class="site-header__nav container">
    <a class="site-header__brand" href={url('/')}>
      <img
        src={`${base}images/logo-redrys-uagro.png`}
        alt="Logo REDRYS"
        class="site-header__brand-logo"
        width="36"
        height="36"
      />
      <span class="site-header__brand-text">REDRYS</span>
    </a>

    <div class="desktop-nav">
      {navLinks.map((link) => (
        <a
          class={`nav-link${isActive(link.href) ? ' nav-link--active' : ''}`}
          href={url(link.href)}
        >
          {link.label}
        </a>
      ))}
    </div>

    <div class="site-header__actions">
      <div class="site-header__context">
        Investigación & Desarrollo Regional
      </div>
      <label for="mobile-toggle" class="mobile-toggle-label" aria-label="Abrir menú de navegación">
        <svg class="icon-menu" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
        <svg class="icon-close" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </label>
    </div>
  </nav>

  <div class="mobile-menu">
    {navLinks.map((link) => (
      <a
        class={`nav-link${isActive(link.href) ? ' nav-link--active' : ''}`}
        href={url(link.href)}
      >
        {link.label}
      </a>
    ))}
  </div>
</header>
