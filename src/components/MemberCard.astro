---
interface Props {
  name: string;
  dependency: string;
  role: string;
}

const { name, dependency, role } = Astro.props;

const initials = name
  .split(' ')
  .filter((_, i, arr) => i === 0 || i === arr.length - 1)
  .map((w) => w.charAt(0).toUpperCase())
  .join('');
---

<div class="member-card">
  <div class="member-card__avatar">{initials}</div>
  <div class="member-card__info">
    <div class="member-card__name">{name}</div>
    <div class="member-card__dep">{dependency}</div>
    <div class="member-card__role">{role}</div>
  </div>
</div>
