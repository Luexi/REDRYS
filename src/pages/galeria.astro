---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionTitle from '../components/SectionTitle.astro';
---

<BaseLayout title="Galería" description="Galería fotográfica de la REDRYS — Red de Educación para el Desarrollo Regional y Sostenible.">

  <section class="page-section container">
    <SectionTitle
      label="REDRYS"
      title="Galería"
    />

    <div class="page-placeholder">
      <div class="page-placeholder__icon">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="width: 100%; height: 100%;">
          <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
          <circle cx="8.5" cy="8.5" r="1.5"/>
          <polyline points="21 15 16 10 5 21"/>
        </svg>
      </div>
      <h2 class="page-placeholder__title">Próximamente</h2>
      <p class="page-placeholder__text">
        Esta sección albergará registros fotográficos de eventos, reuniones y actividades
        de la REDRYS. El contenido será incorporado conforme se desarrollen las actividades de la red.
      </p>
    </div>
  </section>

</BaseLayout>
