---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionTitle from '../components/SectionTitle.astro';
import MemberCard from '../components/MemberCard.astro';
import { integrantes } from '../data/integrantes';
---

<BaseLayout title="Integrantes" description="Directorio de miembros fundadores de la REDRYS — Red de Educación para el Desarrollo Regional y Sostenible.">

  <section class="page-section container">
    <SectionTitle
      label="REDRYS"
      title="Integrantes"
      subtitle="La red fue constituida por 23 miembros fundadores provenientes de la Facultad de Contaduría y Administración y la Facultad de Comunicación de la UAGro."
    />

    <div class="cards-grid cards-grid--3">
      {integrantes.map((member) => (
        <MemberCard
          name={member.name}
          dependency={member.dependency}
          role={member.role}
        />
      ))}
    </div>
  </section>

</BaseLayout>
