---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionTitle from '../components/SectionTitle.astro';
---

<BaseLayout title="Repositorio" description="Repositorio académico de la REDRYS — publicaciones, ponencias y material de investigación.">

  <section class="page-section container">
    <SectionTitle
      label="REDRYS"
      title="Repositorio"
      subtitle="Espacio dedicado a la difusión de producción académica generada por los integrantes de la red."
    />

    <div class="page-placeholder">
      <div class="page-placeholder__icon">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="width: 100%; height: 100%;">
          <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
          <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
        </svg>
      </div>
      <h2 class="page-placeholder__title">Próximamente</h2>
      <p class="page-placeholder__text">
        Los resultados de investigación serán difundidos en acceso abierto, citando la afiliación
        a la REDRYS y la UAGro, conforme a las políticas de publicación de la red.
      </p>
    </div>

    <div class="placeholder-categories">
      <div class="placeholder-category">
        <h3 class="placeholder-category__title">Publicaciones</h3>
        <span class="placeholder-category__status">Próximamente</span>
      </div>
      <div class="placeholder-category">
        <h3 class="placeholder-category__title">Ponencias</h3>
        <span class="placeholder-category__status">Próximamente</span>
      </div>
      <div class="placeholder-category">
        <h3 class="placeholder-category__title">Material didáctico</h3>
        <span class="placeholder-category__status">Próximamente</span>
      </div>
    </div>
  </section>

</BaseLayout>
