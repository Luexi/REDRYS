---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Inicio" description="REDRYS — Red de Educación para el Desarrollo Regional y Sostenible. Una red académica para pensar, vincular y transformar el desarrollo regional.">

  <section class="hero container">
    <div class="hero__grid">
      <!-- Hero Content (Left Column) -->
      <div class="hero__content">
        <div class="hero__eyebrow">
          <span class="hero__eyebrow-line"></span>
          <span class="hero__eyebrow-text">REDRYS · Red de investigación y formación</span>
        </div>

        <h1 class="hero__headline">
          Una red académica para pensar, vincular y transformar el desarrollo regional
        </h1>

        <p class="hero__summary">
          REDRYS reúne a profesores-investigadores, estudiantes de posgrado y colaboradores
          para impulsar investigación aplicada, difusión del conocimiento y soluciones
          con impacto social.
        </p>

        <div class="hero__cta-row">
          <a class="btn btn--primary" href={`${base}la-red/`}>
            Conoce la red
          </a>
          <div class="hero__attribution">
            <span class="hero__attribution-label">Adscripción</span>
            <span class="hero__attribution-value">Facultad de Contaduría y Administración · UAGro</span>
          </div>
        </div>
      </div>

      <!-- Editorial Layout (Right Column) -->
      <div class="hero__editorial">
        <div class="hero__editorial-grid">
          <div class="hero__img-primary">
            <div class="img-placeholder" style="aspect-ratio: 3/4;">
              <span>Investigación académica</span>
            </div>
          </div>

          <div class="hero__img-secondary-wrap">
            <div class="hero__img-secondary">
              <div class="img-placeholder" style="aspect-ratio: 4/5;">
                <span>Colaboración universitaria</span>
              </div>
            </div>

            <div class="academic-card hero__academic-card">
              <div class="corner-bracket"></div>
              <p class="card-title">Red académica multidisciplinaria</p>
              <div class="thin-rule" style="margin-top: 1rem;"></div>
              <p class="card-caption">Fundada en rigor científico</p>
            </div>
          </div>
        </div>

        <div class="hero__decorative-corner"></div>
      </div>
    </div>
  </section>

</BaseLayout>
